# Copy to .env (or export these) to enable the real, production backends.
# With NO keys set, GroupThink runs in offline mode: a mock transcriber and a
# keyword-based analyzer, so you can exercise the whole pipeline and UI.

# --- Theme analysis (Claude) ---------------------------------------------- #
# The judgement-heavy step. Without this, a naive keyword grouping is used.
ANTHROPIC_API_KEY=
# Optional override; defaults to the strongest model for this task.
ANALYSIS_MODEL=claude-opus-4-8

# --- Transcription + diarization ------------------------------------------ #
# Focus groups need accurate speaker labels. AssemblyAI provides strong
# diarization with word-level timecodes. Without this, the mock transcriber runs.
ASR_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=

# --- Rendering ------------------------------------------------------------- #
# RENDER_FPS=30
# TITLE_CARD_SECONDS=3.0
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe

# Where uploads and renders are written.
# GROUPTHINK_WORK_DIR=./workspace

# Note: keys pasted into the web UI are also saved to ~/.groupthink/keys.json
# (user-only) so they persist across restarts. Use "Forget saved keys" to clear.
